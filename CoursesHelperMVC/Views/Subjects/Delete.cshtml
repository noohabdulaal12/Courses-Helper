@model Subject

@{
    ViewData["Title"] = "Delete Subject";
    var hasCourses = Model.Courses.Any();
}

<div class="mb-4">
    <h1 class="h3 mb-1">Delete subject</h1>
    <p class="text-muted mb-0">Confirm removing this subject from the catalog.</p>
</div>

@if (hasCourses)
{
    <div class="alert alert-danger" role="alert">
        <strong>@Model.Name</strong> cannot be deleted because it has @Model.Courses.Count related course(s).
    </div>
}
else
{
    <div class="alert alert-warning" role="alert">
        Deleting <strong>@Model.Name</strong> cannot be undone.
    </div>
}

<dl class="row">
    <dt class="col-sm-3">Courses</dt>
    <dd class="col-sm-9">@Model.Courses.Count</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">
        @if (string.IsNullOrWhiteSpace(Model.Description))
        {
            <span class="text-muted">No description provided.</span>
        }
        else
        {
            @Model.Description
        }
    </dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger" disabled="@hasCourses">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
