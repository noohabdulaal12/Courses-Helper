@model IEnumerable<Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Courses</h1>
        <p class="text-muted mb-0">Manage training courses and their subject assignments.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create course</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Subject</th>
                <th class="text-end">Sessions</th>
                <th class="text-end">Price</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@course.Name</div>
                    @if (!string.IsNullOrWhiteSpace(course.Description))
                    {
                        <div class="text-muted small text-truncate course-description-preview">@course.Description</div>
                    }
                </td>
                <td>@course.Subject?.Name</td>
                <td class="text-end">@course.NumberOfSessions</td>
                <td class="text-end">@course.Price.ToString("C")</td>
                <td class="text-end">
                    <div class="btn-group" role="group" aria-label="Course actions">
                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center border rounded p-5">
        <h2 class="h5">No courses yet</h2>
        <p class="text-muted">Create the first course to start managing the catalog.</p>
        <a asp-action="Create" class="btn btn-primary">Create course</a>
    </div>
}
