@model CoursesHelperWebAPI.Models.App.CertificationCourse

@{
    ViewData["Title"] = "Required Course Details";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Required Course Details</h1>
        <p class="text-muted mb-0">Review the certification-course requirement.</p>
    </div>
    <div class="table-actions">
        <a asp-controller="Certifications" asp-action="Details" asp-route-id="@Model.CertificationId" class="btn btn-outline-secondary">Back to Certification</a>
        <a asp-action="Delete" asp-route-certificationId="@Model.CertificationId" asp-route-courseId="@Model.CourseId" class="btn btn-outline-danger">Remove</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Certification</dt>
    <dd class="col-sm-9">@(Model.Certification?.Name ?? "Unknown certification")</dd>
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@(Model.Course?.Name ?? "Unknown course")</dd>
</dl>
