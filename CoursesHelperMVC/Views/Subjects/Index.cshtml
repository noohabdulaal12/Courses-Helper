@model IEnumerable<Subject>

@{
    ViewData["Title"] = "Subjects";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Subjects</h1>
        <p class="text-muted mb-0">Manage subject areas used to organize courses.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create subject</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th class="text-end">Courses</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var subject in Model)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@subject.Name</div>
                    @if (!string.IsNullOrWhiteSpace(subject.Description))
                    {
                        <div class="text-muted small text-truncate subject-description-preview">@subject.Description</div>
                    }
                </td>
                <td class="text-end">@subject.Courses.Count</td>
                <td class="text-end">
                    <div class="btn-group" role="group" aria-label="Subject actions">
                        <a asp-action="Details" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center border rounded p-5">
        <h2 class="h5">No subjects yet</h2>
        <p class="text-muted">Create the first subject to organize the course catalog.</p>
        <a asp-action="Create" class="btn btn-primary">Create subject</a>
    </div>
}
