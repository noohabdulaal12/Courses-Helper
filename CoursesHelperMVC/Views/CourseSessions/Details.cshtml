@model CourseSession
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Course Session Details";
    var webApiBaseUrl = Configuration["WebApi:BaseUrl"]?.TrimEnd('/');
    var webApiHubUrl = string.IsNullOrWhiteSpace(webApiBaseUrl) ? null : $"{webApiBaseUrl}/enrollmentHub";
    var remainingSeats = Math.Max(0, Model.MaxSeats - Model.TraineeSessions.Count);
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4"
     data-enrollment-hub-url="/enrollmentHub"
     data-enrollment-hub-url-api="@webApiHubUrl">
    <div>
        <h1 class="h3 mb-1">@Model.Course.Name</h1>
        <p class="text-muted mb-0">Course session details</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to sessions</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.Course.Name</dd>

    <dt class="col-sm-3">Instructor</dt>
    <dd class="col-sm-9">@CourseSessionsController.FormatInstructor(Model.Instructor)</dd>

    <dt class="col-sm-3">Classroom</dt>
    <dd class="col-sm-9">@CourseSessionsController.FormatClassroom(Model.Classroom)</dd>

    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.StartingDate.ToString("yyyy-MM-dd") (@Model.DayOfWeek)</dd>

    <dt class="col-sm-3">Time</dt>
    <dd class="col-sm-9">@Model.StartingTime.ToString(@"hh\:mm") - @Model.EndingTime.ToString(@"hh\:mm")</dd>

    <dt class="col-sm-3">Max seats</dt>
    <dd class="col-sm-9">@Model.MaxSeats</dd>

    <dt class="col-sm-3">Remaining seats</dt>
    <dd class="col-sm-9">
        <span class="badge @(remainingSeats <= 0 ? "bg-danger" : "bg-success")"
              data-seat-counter
              data-session-id="@Model.Id"
              data-max-seats="@Model.MaxSeats"
              data-remaining-seats="@remainingSeats">
            @remainingSeats / @Model.MaxSeats
        </span>
    </dd>
</dl>

@section Scripts {
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script src="~/js/enrollment-counter.js" asp-append-version="true"></script>
}
