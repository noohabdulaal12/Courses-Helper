@model CoursesHelperWebAPI.Models.App.TraineeQualification

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>TraineeQualification</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Trainee)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Trainee.Email)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Course)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Course.Name)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-traineeId="@Model.TraineeId" asp-route-courseId="@Model.CourseId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
