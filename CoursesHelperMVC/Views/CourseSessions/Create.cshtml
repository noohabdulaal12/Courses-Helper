@model CourseSessionFormViewModel

@{
    ViewData["Title"] = "Create Course Session";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Create session</h1>
    <p class="text-muted mb-0">Schedule a course with an instructor and classroom.</p>
</div>

<form asp-action="Create" method="post" class="session-form">
    <partial name="_CourseSessionForm" model="Model" />
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
