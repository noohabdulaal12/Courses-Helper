@model HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="home-hero mb-4">
    <div>
        @if (!string.IsNullOrWhiteSpace(Model.RoleName))
        {
            <div class="home-role">@Model.RoleName workspace</div>
        }
        <h1 class="h3 mb-2">Welcome, @Model.DisplayName</h1>
        <p class="text-muted mb-0">@Model.IntroText</p>
    </div>
</div>

<div class="home-option-grid">
    @foreach (var option in Model.Options)
    {
        <a asp-controller="@option.Controller" asp-action="@option.Action" class="home-option-card text-decoration-none">
            <span class="home-option-category">@option.Category</span>
            <span class="home-option-title">@option.Title</span>
            <span class="home-option-description">@option.Description</span>
        </a>
    }
</div>
