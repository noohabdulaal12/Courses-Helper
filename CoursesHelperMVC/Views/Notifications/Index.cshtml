@model IEnumerable<CoursesHelperWebAPI.Models.App.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Notifications</h1>
        <p class="text-muted mb-0">Updates about your sessions, enrollments, assessments, and coordinator actions.</p>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary">Mark all read</button>
        </form>
    }
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">You do not have any notifications yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var notification in Model)
        {
            <div class="list-group-item @(notification.IsRead ? string.Empty : "list-group-item-primary")">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="fw-semibold">@notification.Title</div>
                        <div>@notification.Message</div>
                        <div class="small text-muted mt-1">@notification.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="text-end">
                        @if (!string.IsNullOrWhiteSpace(notification.Link))
                        {
                            <a href="@notification.Link" class="btn btn-sm btn-outline-primary mb-2">Open</a>
                        }
                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkRead" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Mark read</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
