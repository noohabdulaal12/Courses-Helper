@model IEnumerable<CertificationProgressViewModel>

@{
    ViewData["Title"] = "Certification Progress";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Certification progress</h1>
    <p class="text-muted mb-0">Track required, completed, and pending courses for your assigned certification tracks.</p>
</div>

@foreach (var certification in Model)
{
    <div class="border rounded p-3 mb-3">
        <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
            <h2 class="h5 mb-0">@certification.CertificationName</h2>
            @if (certification.IsEligible)
            {
                <span class="badge bg-success">Eligible</span>
            }
            else
            {
                <span class="badge bg-secondary">Not eligible</span>
            }
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="fw-semibold">Required</div>
                @if (certification.RequiredCourses.Any())
                {
                    <ul class="mb-0">
                        @foreach (var course in certification.RequiredCourses)
                        {
                            <li>@course</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No required courses have been set yet.</p>
                }
            </div>
            <div class="col-md-4">
                <div class="fw-semibold">Completed</div>
                @if (certification.CompletedCourses.Any())
                {
                    <ul class="mb-0">
                        @foreach (var course in certification.CompletedCourses)
                        {
                            <li>@course</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No required courses completed yet.</p>
                }
            </div>
            <div class="col-md-4">
                <div class="fw-semibold">Pending</div>
                @if (certification.PendingCourses.Any())
                {
                    <ul class="mb-0">
                        @foreach (var course in certification.PendingCourses)
                        {
                            <li>@course</li>
                        }
                    </ul>
                }
                else if (certification.RequiredCourses.Any())
                {
                    <p class="text-muted mb-0">No pending courses.</p>
                }
                else
                {
                    <p class="text-muted mb-0">Waiting for certification requirements.</p>
                }
            </div>
        </div>
    </div>
}
@if (!Model.Any())
{
    <div class="alert alert-info">
        You are not assigned to any certification tracks yet.
    </div>
}
