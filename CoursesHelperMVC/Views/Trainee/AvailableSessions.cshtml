@model IEnumerable<AvailableSessionViewModel>

@{
    ViewData["Title"] = "Available Sessions";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Available sessions</h1>
    <p class="text-muted mb-0">Browse upcoming sessions and request enrollment.</p>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Course</th>
                <th>Instructor</th>
                <th>Classroom</th>
                <th>Date</th>
                <th>Time</th>
                <th class="text-end">Remaining</th>
                <th class="text-end">Price</th>
                <th class="text-end">Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var session in Model)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@session.CourseName</div>
                    <div class="text-muted small">@session.SubjectName</div>
                </td>
                <td>@session.InstructorName</td>
                <td>@session.ClassroomName</td>
                <td>@session.StartingDate.ToString("yyyy-MM-dd")</td>
                <td>@session.StartingTime.ToString(@"hh\:mm") - @session.EndingTime.ToString(@"hh\:mm")</td>
                <td class="text-end">@session.RemainingSeats / @session.MaxSeats</td>
                <td class="text-end">@session.Price.ToString("C")</td>
                <td class="text-end">
                    @if (session.IsAlreadyEnrolled)
                    {
                        <span class="badge bg-secondary">Enrolled</span>
                    }
                    else if (session.RemainingSeats <= 0)
                    {
                        <span class="badge bg-danger">Full</span>
                    }
                    else
                    {
                        <form asp-action="Enroll" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sessionId" value="@session.SessionId" />
                            <button type="submit" class="btn btn-sm btn-primary">Enroll</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
