@model IEnumerable<CoursesHelperWebAPI.Models.App.ClassroomType>

@{
    ViewData["Title"] = "Classroom Types";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Delivery</p>
        <h1>Classroom Types</h1>
        <p class="text-muted mb-0">Define room categories and capacities used when scheduling sessions.</p>
    </div>
    <div class="table-actions">
        <a asp-controller="Classrooms" asp-action="Index" class="btn btn-outline-secondary">Classrooms</a>
        <a asp-action="Create" class="btn btn-primary">Add Type</a>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Capacity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Capacity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <div class="table-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
}
@if (!Model.Any())
{
        <tr>
            <td colspan="4" class="text-center text-muted py-4">No classroom types have been added yet.</td>
        </tr>
}
    </tbody>
</table>
