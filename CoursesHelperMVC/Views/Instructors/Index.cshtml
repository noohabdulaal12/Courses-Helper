@model IEnumerable<InstructorListItemViewModel>

@{
    ViewData["Title"] = "Instructors";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Instructors</h1>
    <p class="text-muted mb-0">Manage instructor expertise, availability, and assigned sessions.</p>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Instructor</th>
                <th>Email</th>
                <th class="text-end">Qualified courses</th>
                <th class="text-end">Availability slots</th>
                <th class="text-end">Assigned sessions</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var instructor in Model)
        {
            <tr>
                <td class="fw-semibold">@instructor.Name</td>
                <td>@instructor.Email</td>
                <td class="text-end">@instructor.QualifiedCourseCount</td>
                <td class="text-end">@instructor.AvailabilitySlotCount</td>
                <td class="text-end">@instructor.AssignedSessionCount</td>
                <td class="text-end">
                    <div class="btn-group" role="group" aria-label="Instructor actions">
                        <a asp-action="Details" asp-route-id="@instructor.InstructorId" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="EditQualifications" asp-route-id="@instructor.InstructorId" class="btn btn-sm btn-outline-primary">Expertise</a>
                        <a asp-action="Availability" asp-route-id="@instructor.InstructorId" class="btn btn-sm btn-outline-primary">Availability</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h2 class="h5">No instructor users found</h2>
        <p class="text-muted mb-0">Instructor users will appear here when they exist in Identity.</p>
    </div>
}
