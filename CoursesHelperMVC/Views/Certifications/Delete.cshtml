@model CoursesHelperWebAPI.Models.App.Certification

@{
    ViewData["Title"] = "Delete Certification";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Delete Certification</h1>
        <p class="text-muted mb-0">Remove a certification only when it is no longer assigned to trainees.</p>
    </div>
</div>

<h2 class="h5">Are you sure you want to delete this certification?</h2>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)</dd>
</dl>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to Details</a>
</form>
