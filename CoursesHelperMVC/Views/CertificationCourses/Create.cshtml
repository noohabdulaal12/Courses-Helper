@model CoursesHelperWebAPI.Models.App.CertificationCourse

@{
    ViewData["Title"] = "Add Required Course";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Add Required Course</h1>
        <p class="text-muted mb-0">Assign a course that trainees must complete for a certification track.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="CertificationId" class="form-label">Certification</label>
                <select asp-for="CertificationId" class="form-control" asp-items="ViewBag.CertificationId"></select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="CourseId" class="form-label">Course</label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId"></select>
            </div>
            <div class="form-group button-row">
                <input type="submit" value="Add Required Course" class="btn btn-primary" />
                @if (Model.CertificationId > 0)
                {
                    <a asp-action="Index" asp-route-certificationId="@Model.CertificationId" class="btn btn-outline-secondary">Back to Required Courses</a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to Required Courses</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
