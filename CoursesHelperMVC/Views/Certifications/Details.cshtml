@model CoursesHelperWebAPI.Models.App.Certification

@{
    ViewData["Title"] = "Certification Details";
    var requiredCourses = Model.CertificationCourses
        .Where(cc => cc.Course is not null)
        .OrderBy(cc => cc.Course!.Name)
        .ToList();
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>@Model.Name</h1>
        <p class="text-muted mb-0">Review certification details and manage required courses.</p>
    </div>
    <div class="table-actions">
        <a asp-controller="CertificationCourses" asp-action="Index" asp-route-certificationId="@Model.Id" class="btn btn-primary">Manage Required Courses</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<section class="mb-4">
    <h2 class="h5">Overview</h2>
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>
        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)</dd>
        <dt class="col-sm-3">Required Courses</dt>
        <dd class="col-sm-9">@requiredCourses.Count course(s)</dd>
    </dl>
</section>

<section>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Required Courses</h2>
        <a asp-controller="CertificationCourses" asp-action="Create" asp-route-certificationId="@Model.Id" class="btn btn-sm btn-outline-primary">Add Required Course</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Course</th>
                <th>Subject</th>
                <th>Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in requiredCourses)
{
            <tr>
                <td class="fw-semibold">@item.Course!.Name</td>
                <td>@(item.Course.Subject?.Name ?? "Not set")</td>
                <td>@item.Course.Price.ToString("C")</td>
                <td>
                    <div class="table-actions">
                        <a asp-controller="CertificationCourses" asp-action="Details" asp-route-certificationId="@item.CertificationId" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-controller="CertificationCourses" asp-action="Delete" asp-route-certificationId="@item.CertificationId" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-danger">Remove</a>
                    </div>
                </td>
            </tr>
}
@if (!requiredCourses.Any())
{
            <tr>
                <td colspan="4" class="text-center text-muted py-4">No required courses are assigned to this certification yet.</td>
            </tr>
}
        </tbody>
    </table>
</section>
