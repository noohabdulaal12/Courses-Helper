@model IEnumerable<CoursesHelperWebAPI.Models.App.Certification>

@{
    ViewData["Title"] = "Certifications";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Certifications</h1>
        <p class="text-muted mb-0">Manage certification tracks and the courses trainees must complete.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Certification</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Required Courses</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td class="fw-semibold">@item.Name</td>
            <td>@(string.IsNullOrWhiteSpace(item.Description) ? "No description" : item.Description)</td>
            <td>
                <span class="status-badge status-confirmed">@item.CertificationCourses.Count course(s)</span>
            </td>
            <td>
                <div class="table-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
}
@if (!Model.Any())
{
        <tr>
            <td colspan="4" class="text-center text-muted py-4">No certifications have been added yet.</td>
        </tr>
}
    </tbody>
</table>
