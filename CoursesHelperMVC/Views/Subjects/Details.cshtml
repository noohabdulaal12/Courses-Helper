@model Subject

@{
    ViewData["Title"] = "Subject Details";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <p class="text-muted mb-0">Subject details</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to subjects</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Courses</dt>
    <dd class="col-sm-9">@Model.Courses.Count</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">
        @if (string.IsNullOrWhiteSpace(Model.Description))
        {
            <span class="text-muted">No description provided.</span>
        }
        else
        {
            @Model.Description
        }
    </dd>
</dl>

@if (Model.Courses.Any())
{
    <h2 class="h5 mt-4">Courses in this subject</h2>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th class="text-end">Sessions</th>
                    <th class="text-end">Price</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var course in Model.Courses.OrderBy(c => c.Name))
            {
                <tr>
                    <td>
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id">@course.Name</a>
                    </td>
                    <td class="text-end">@course.NumberOfSessions</td>
                    <td class="text-end">@course.Price.ToString("C")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
