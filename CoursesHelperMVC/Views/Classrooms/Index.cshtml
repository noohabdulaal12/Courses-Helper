@model IEnumerable<CoursesHelperWebAPI.Models.App.Classroom>

@{
    ViewData["Title"] = "Classrooms";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Delivery</p>
        <h1>Classrooms</h1>
        <p class="text-muted mb-0">Manage physical or online rooms used for scheduled course sessions.</p>
    </div>
    <div class="table-actions">
        <a asp-controller="ClassroomTypes" asp-action="Index" class="btn btn-outline-secondary">Classroom Types</a>
        <a asp-action="Create" class="btn btn-primary">Add Classroom</a>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                Description
            </th>
            <th>
                Type
            </th>
            <th>
                Capacity
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @(item.ClassroomType?.Name ?? "Not set")
            </td>
            <td>
                <span class="status-badge status-confirmed">@((item.ClassroomType?.Capacity.ToString()) ?? "-") seats</span>
            </td>
            <td>
                <div class="table-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
}
@if (!Model.Any())
{
        <tr>
            <td colspan="4" class="text-center text-muted py-4">No classrooms have been added yet.</td>
        </tr>
}
    </tbody>
</table>
