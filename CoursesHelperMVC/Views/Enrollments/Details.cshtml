@model TraineeSession

@{
    ViewData["Title"] = "Enrollment Details";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@EnrollmentsController.FormatTrainee(Model.Trainee)</h1>
        <p class="text-muted mb-0">Enrollment details</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-traineeId="@Model.TraineeId" asp-route-sessionId="@Model.SessionId" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to enrollments</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Trainee</dt>
    <dd class="col-sm-9">@EnrollmentsController.FormatTrainee(Model.Trainee)</dd>

    <dt class="col-sm-3">Session</dt>
    <dd class="col-sm-9">@EnrollmentsController.FormatSession(Model.CourseSession)</dd>

    <dt class="col-sm-3">Classroom</dt>
    <dd class="col-sm-9">@CourseSessionsController.FormatClassroom(Model.CourseSession.Classroom)</dd>

    <dt class="col-sm-3">Amount paid</dt>
    <dd class="col-sm-9">@Model.AmountPaid.ToString("C")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>
