@model CoursesHelperWebAPI.Models.App.Classroom

@{
    ViewData["Title"] = "Classroom Details";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Delivery</p>
        <h1>Classroom Details</h1>
        <p class="text-muted mb-0">Review room type, capacity, and description.</p>
    </div>
</div>

<div>
    <h4>Classroom</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ClassroomType)
        </dt>
        <dd class = "col-sm-10">
            @(Model.ClassroomType?.Name ?? "Not set")
        </dd>
        <dt class = "col-sm-2">
            Capacity
        </dt>
        <dd class = "col-sm-10">
            @(Model.ClassroomType?.Capacity.ToString() ?? "-") seats
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
