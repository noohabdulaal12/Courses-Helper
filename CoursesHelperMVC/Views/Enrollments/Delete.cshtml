@model TraineeSession

@{
    ViewData["Title"] = "Delete Enrollment";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Delete enrollment</h1>
    <p class="text-muted mb-0">Confirm removing this trainee registration.</p>
</div>

<div class="alert alert-warning" role="alert">
    Removing <strong>@EnrollmentsController.FormatTrainee(Model.Trainee)</strong> from this session cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Session</dt>
    <dd class="col-sm-9">@EnrollmentsController.FormatSession(Model.CourseSession)</dd>

    <dt class="col-sm-3">Amount paid</dt>
    <dd class="col-sm-9">@Model.AmountPaid.ToString("C")</dd>

    <dt class="col-sm-3">Payment due date</dt>
    <dd class="col-sm-9">@(Model.PaymentDueDate?.ToString("yyyy-MM-dd") ?? "Not set")</dd>

    <dt class="col-sm-3">Payment status</dt>
    <dd class="col-sm-9">
        <partial name="_PaymentStatusBadge"
                 model="PaymentStatusHelper.Calculate(Model.CourseSession.Course.Price, Model.AmountPaid, Model.PaymentDueDate)" />
    </dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9"><partial name="_StatusBadge" model="Model.Status" /></dd>
</dl>

<form asp-action="Delete" asp-route-traineeId="@Model.TraineeId" asp-route-sessionId="@Model.SessionId" method="post">
    <input type="hidden" asp-for="TraineeId" />
    <input type="hidden" asp-for="SessionId" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
