@model CoursesHelperWebAPI.Models.App.CertificationCourse

@{
    ViewData["Title"] = "Remove Required Course";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Remove Required Course</h1>
        <p class="text-muted mb-0">Remove this course requirement from the certification track.</p>
    </div>
</div>

<h2 class="h5">Are you sure you want to remove this required course?</h2>

<dl class="row">
    <dt class="col-sm-3">Certification</dt>
    <dd class="col-sm-9">@(Model.Certification?.Name ?? "Unknown certification")</dd>
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@(Model.Course?.Name ?? "Unknown course")</dd>
</dl>

<form asp-action="Delete" asp-route-certificationId="@Model.CertificationId" asp-route-courseId="@Model.CourseId">
    <input type="hidden" asp-for="CertificationId" />
    <input type="hidden" asp-for="CourseId" />
    <input type="submit" value="Remove" class="btn btn-danger" />
    <a asp-action="Index" asp-route-certificationId="@Model.CertificationId" class="btn btn-outline-secondary">Back to Required Courses</a>
</form>
