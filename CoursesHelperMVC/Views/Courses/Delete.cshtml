@model Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Delete course</h1>
    <p class="text-muted mb-0">Confirm removing this course from the catalog.</p>
</div>

<div class="alert alert-warning" role="alert">
    Deleting <strong>@Model.Name</strong> cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Subject</dt>
    <dd class="col-sm-9">@Model.Subject?.Name</dd>

    <dt class="col-sm-3">Sessions</dt>
    <dd class="col-sm-9">@Model.NumberOfSessions</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("C")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
