@{
    ViewData["Title"] = "Home";
}

<div class="py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="display-6 mb-2">Training Management</h1>
            <p class="lead text-muted mb-0">Manage the course catalog with direct MVC access to the shared data model.</p>
        </div>
        <a asp-controller="Courses" asp-action="Index" class="btn btn-primary btn-lg">Manage courses</a>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Courses</h2>
                <p class="text-muted mb-0">Create, update, view, and delete catalog courses.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Subjects</h2>
                <p class="text-muted mb-0">Courses are organized by the subjects already stored in the shared database.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Certification Lookup</h2>
                <p class="text-muted mb-0">Reserved for the later public page that will call the Web API.</p>
            </div>
        </div>
    </div>
</div>
