@model CoursesHelperWebAPI.Models.App.CertificationCourse

@{
    ViewData["Title"] = "Edit Required Course";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Certification</p>
        <h1>Edit Required Course</h1>
        <p class="text-muted mb-0">This requirement is identified by its certification and course.</p>
    </div>
</div>

<div class="alert alert-info">
    To change this requirement, remove it and add the correct required course.
</div>

<form asp-action="Edit" asp-route-certificationId="@Model.CertificationId" asp-route-courseId="@Model.CourseId">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="CertificationId" />
    <input type="hidden" asp-for="CourseId" />
    <div class="button-row">
        <input type="submit" value="Save" class="btn btn-primary" />
        <a asp-action="Index" asp-route-certificationId="@Model.CertificationId" class="btn btn-outline-secondary">Back to Required Courses</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
