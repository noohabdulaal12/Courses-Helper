@model CourseFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="SubjectId" class="form-label"></label>
        <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-select">
            <option value="">Choose a subject</option>
        </select>
        <span asp-validation-for="SubjectId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="NumberOfSessions" class="form-label"></label>
        <input asp-for="NumberOfSessions" class="form-control" min="1" />
        <span asp-validation-for="NumberOfSessions" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" min="0.01" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
</div>
